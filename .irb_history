relation_type = 'same_extension'
def filter_fids(fids:, relation_type: nil, source: nil)\
  _fids = fids.select do |(rel_type, rel_source), _|\
    (relation_type.nil? || rel_type == relation_type) &&\
    (source.nil? || rel_source == source)\
  end\
end
